#!/bin/bash

# System Update Script for MX-Linux 25
# Runs updates, upgrades, cleans orphaned packages, checks reboot requirement
# Sends notifications to Telegram bot

set -euo pipefail

# Configuration
TELEGRAM_BOT_TOKEN="YOUR TELEGRAM TOKEN HERE"
TELEGRAM_CHAT_ID="YOUR TELEGRAM ID HERE"
LOG_FILE="/var/log/system-update.log"

# Function to send Telegram notification
send_telegram() {
    local message="$1"
    local parse_mode="${2:-}"
    
    if [ -n "$parse_mode" ]; then
        curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
            -d chat_id="${TELEGRAM_CHAT_ID}" \
            -d text="${message}" \
            -d parse_mode="${parse_mode}" > /dev/null 2>&1
    else
        curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
            -d chat_id="${TELEGRAM_CHAT_ID}" \
            -d text="${message}" > /dev/null 2>&1
    fi
}

# Function to log messages
log_message() {
    local message="$1"
    echo "$(date '+%Y-%m-%d %H:%M:%S') - ${message}" >> "$LOG_FILE"
}

# Main execution
main() {
    local start_time=$(date '+%Y-%m-%d %H:%M:%S')
    local errors=()
    local success_messages=()
    
    log_message "Starting system update script"
    
    # Check if running as root
    if [ "$EUID" -ne 0 ]; then
        send_telegram "❌ ERROR: System update script must be run as root"
        log_message "ERROR: Script must be run as root"
        exit 1
    fi
    
    # Update package lists with retry logic
    log_message "Updating package lists..."
    local update_success=false
    for attempt in 1 2 3; do
        log_message "Package update attempt ${attempt} of 3..."
        if apt-get update -y >> "$LOG_FILE" 2>&1; then
            update_success=true
            break
        else
            log_message "Attempt ${attempt} failed, waiting 30 seconds before retry..."
            sleep 30
        fi
    done
    
    if [ "$update_success" = true ]; then
        success_messages+=("✅ Package lists updated successfully")
        log_message "Package lists updated successfully"
    else
        errors+=("❌ Failed to update package lists after 3 attempts")
        log_message "ERROR: Failed to update package lists after 3 attempts"
    fi
    
    # Upgrade packages
    log_message "Upgrading packages..."
    if DEBIAN_FRONTEND=noninteractive apt-get upgrade -y >> "$LOG_FILE" 2>&1; then
        success_messages+=("✅ Packages upgraded successfully")
        log_message "Packages upgraded successfully"
    else
        errors+=("❌ Failed to upgrade packages")
        log_message "ERROR: Failed to upgrade packages"
    fi
    
    # Perform dist-upgrade for system updates
    log_message "Performing dist-upgrade..."
    if DEBIAN_FRONTEND=noninteractive apt-get dist-upgrade -y >> "$LOG_FILE" 2>&1; then
        success_messages+=("✅ Dist-upgrade completed successfully")
        log_message "Dist-upgrade completed successfully"
    else
        errors+=("❌ Failed to perform dist-upgrade")
        log_message "ERROR: Failed to perform dist-upgrade"
    fi
    
    # Autoremove unnecessary packages
    log_message "Autoremoving unnecessary packages..."
    if apt-get autoremove -y >> "$LOG_FILE" 2>&1; then
        success_messages+=("✅ Unnecessary packages autoremoved")
        log_message "Unnecessary packages autoremoved"
    else
        errors+=("❌ Failed to autoremove packages")
        log_message "ERROR: Failed to autoremove packages"
    fi
    
    # Clean apt cache
    log_message "Cleaning apt cache..."
    if apt-get clean >> "$LOG_FILE" 2>&1; then
        success_messages+=("✅ Apt cache cleaned")
        log_message "Apt cache cleaned"
    else
        errors+=("❌ Failed to clean apt cache")
        log_message "ERROR: Failed to clean apt cache"
    fi
    
    # Check and remove orphaned packages (packages no longer required)
    log_message "Checking for orphaned packages..."
    local orphan_count=$(apt-get autoremove --purge -y --dry-run 2>/dev/null | grep -c "^Remv" || true)
    if [ "$orphan_count" -gt 0 ]; then
        if apt-get autoremove --purge -y >> "$LOG_FILE" 2>&1; then
            success_messages+=("✅ Removed ${orphan_count} orphaned package(s)")
            log_message "Removed ${orphan_count} orphaned packages"
        else
            errors+=("❌ Failed to remove orphaned packages")
            log_message "ERROR: Failed to remove orphaned packages"
        fi
    else
        success_messages+=("✅ No orphaned packages found")
        log_message "No orphaned packages found"
    fi
    
    # Check if reboot is required
    log_message "Checking if reboot is required..."
    local reboot_required=false
    if [ -f /var/run/reboot-required ]; then
        reboot_required=true
        local reboot_pkgs=""
        if [ -f /var/run/reboot-required.pkgs ]; then
            reboot_pkgs=$(cat /var/run/reboot-required.pkgs)
        fi
        success_messages+=("⚠️ REBOOT REQUIRED")
        if [ -n "$reboot_pkgs" ]; then
            success_messages+=("Packages requiring reboot: ${reboot_pkgs}")
        fi
        log_message "Reboot is required"
    else
        success_messages+=("✅ No reboot required")
        log_message "No reboot required"
    fi
    
    # Prepare notification message
    local notification="🔄 *System Update Report*\n"
    notification+="📅 ${start_time}\n"
    notification+="🖥️ $(hostname)\n\n"
    
    # Add success messages
    for msg in "${success_messages[@]}"; do
        notification+="${msg}\n"
    done
    
    # Add errors if any
    if [ ${#errors[@]} -gt 0 ]; then
        notification+="\n❌ *Errors encountered:*\n"
        for err in "${errors[@]}"; do
            notification+="${err}\n"
        done
    fi
    
    # Add reboot notice if required
    if [ "$reboot_required" = true ]; then
        notification+="\n⚠️ *Action required:* System reboot needed to complete updates"
    fi
    
    # Send notification
    send_telegram "$(echo -e "$notification")" "Markdown"
    
    # Log completion
    if [ ${#errors[@]} -eq 0 ]; then
        log_message "System update completed successfully"
    else
        log_message "System update completed with ${#errors[@]} error(s)"
    fi
    
    exit 0
}

# Run main function
main "$@"
